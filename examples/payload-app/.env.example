# This example app uses the SQLite adapter (@payloadcms/db-sqlite).
# Use a local file URL, or a libSQL/Turso URL + auth token.
DATABASE_URL=file:./payload.db
# TURSO_AUTH_TOKEN=

# Payload's signing secret. Generate one with: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public base URL of this app. Used as the OAuth `issuer` and to build the URLs
# advertised in the discovery metadata. In production this MUST be the real
# external HTTPS URL clients reach (e.g. https://cms.example.com).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# HMAC pepper used to hash OAuth tokens at rest. REQUIRED in production
# (the plugin throws on boot if it is missing or shorter than 32 chars).
# In development a built-in insecure fallback is used if this is unset.
# Generate one with: openssl rand -hex 32
PMOAUTH_TOKEN_PEPPER=
