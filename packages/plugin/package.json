    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "payload": "3.85.0",
    "@payloadcms/plugin-mcp": "3.85.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "8.3.5",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
