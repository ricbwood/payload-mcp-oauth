  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricbwood/payload-mcp-oauth.git",
    "directory": "packages/plugin"
  },
  "homepage": "https://github.com/ricbwood/payload-mcp-oauth/tree/main/packages/plugin#readme",
