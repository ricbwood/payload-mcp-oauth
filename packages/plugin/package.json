{
  "name": "@brainwebuk/payload-plugin-mcp-oauth",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "require": "./dist/admin/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "payload": "^3.0.0",
    "@payloadcms/plugin-mcp": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "payload": "3.85.0",
    "@payloadcms/plugin-mcp": "3.85.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "8.3.5",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
