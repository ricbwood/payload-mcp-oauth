# Enforce that peer dependencies are explicit. Critical for a plugin
# that declares @payloadcms/plugin-mcp as a peer.
auto-install-peers=false
strict-peer-dependencies=true

# Don't silently hoist arbitrary deps to the workspace root —
# packages must explicitly declare what they use.
hoist=false

# Use the workspace lockfile, never write a per-package one.
shared-workspace-lockfile=true

# Pin exact versions in package.json. Avoids the "works on my machine
# because of a minor bump" class of problem.
save-exact=true